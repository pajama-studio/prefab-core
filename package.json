{
  "name": "@pajama-studio/prefab-core",
  "version": "0.3.2",
  "description": "General-purpose prefab game runtime: prefab schema, deterministic step() over pluggable system packs, extensible trigger/action dispatch. Domain packs plug in on top.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./engine/*": {
      "types": "./dist/engine/*.d.ts",
      "import": "./dist/engine/*.js"
    },
    "./game/*": {
      "types": "./dist/game/*.d.ts",
      "import": "./dist/game/*.js"
    },
    "./schema": {
      "types": "./dist/schema/index.d.ts",
      "import": "./dist/schema/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "AGENTS.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "gen": "tsx scripts/gen-agents-md.mts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pajama-studio/prefab-core.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^3.0.0",
    "tsx": "^4.19.0"
  },
  "homepage": "https://github.com/pajama-studio/prefab-core#readme",
  "bugs": {
    "url": "https://github.com/pajama-studio/prefab-core/issues"
  },
  "keywords": [
    "game-engine",
    "prefab",
    "ecs",
    "kitchen",
    "simulation",
    "typescript"
  ]
}
